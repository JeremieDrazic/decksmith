# Decksmith — Environment Variables
#
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string via Supabase Session Pooler (recommended)
# Found in: Supabase dashboard → Settings → Database → Session pooler
# Note: direct connection (db.<ref>.supabase.co:5432) is deprecated — use the pooler URL
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Supabase project URL and public anon key (safe for client-side use)
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (server-side only — never expose to clients)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── API Server ───────────────────────────────────────────────────────────────
# Port the Fastify API listens on (apps/api)
PORT=3000

# Log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis connection URL (used by apps/worker for BullMQ job queues)
# Local: redis://localhost:6379
# Upstash (production): rediss://user:password@host:6380
REDIS_URL=redis://localhost:6379

# ─── Scryfall ─────────────────────────────────────────────────────────────────
# No API key required for Scryfall.
# Rate limit: 50-100ms between requests (enforced in packages/scryfall).

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Cookie signing secret — used by @fastify/cookie to sign session cookies
# Generate with: openssl rand -base64 64
COOKIE_SECRET=your-cookie-secret-at-least-64-chars
